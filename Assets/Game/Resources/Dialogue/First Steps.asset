  m_Name: 515a1efa-f742-449d-b036-08c486689765
  m_EditorClassIdentifier: Assembly-CSharp::EldwynGrove.Dialogues.DialogueNode
  m_text: Now let's see if you can handle something a bit more hands-on.
  m_children:
  - a972679b-4470-4d10-b175-3b6cf18ca31e
  m_rect:
    serializedVersion: 2
