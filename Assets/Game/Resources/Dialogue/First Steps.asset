  m_Name: d0462e93-33cb-4375-aefd-7a5980eff4bb
  m_EditorClassIdentifier: Assembly-CSharp::EldwynGrove.Dialogues.DialogueNode
  m_text: See those stones scattered around? They're more useful than they look,
    too. Break up 10 rocks and bring me what you got.
  m_children: []
  m_rect:
    serializedVersion: 2
    x: 800
    y: 650
    width: 200
    height: 100
  m_onEnterAction: 
