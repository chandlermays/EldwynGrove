  m_Script: {fileID: 11500000, guid: 7718dc195cbbbb24596c026e6ef36c5e, type: 3}
  m_Name: 5a0394cb-b472-4f52-aba5-54dd992ef8c6
  m_EditorClassIdentifier: Assembly-CSharp::EldwynGrove.Dialogues.DialogueNode
  m_text: If you're serious about making something of yourself out here, you shouldn't
    stay in the fields forever.
  m_children:
  - c03316d2-f85e-40ed-8e8e-e2e30ba2c69f
  m_rect:
    serializedVersion: 2
    x: 550
    y: 950
