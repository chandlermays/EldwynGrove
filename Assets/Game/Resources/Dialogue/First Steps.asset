--- !u!114 &-7040325358530631671
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7718dc195cbbbb24596c026e6ef36c5e, type: 3}
  m_Name: a972679b-4470-4d10-b175-3b6cf18ca31e
  m_EditorClassIdentifier: Assembly-CSharp::EldwynGrove.Dialogues.DialogueNode
  m_text: There's wild growth all over this place--vines, weeds, that sort of thing.
    Clear out 10 bundles of fiber and bring 'em back.
  m_children: []
  m_rect:
    serializedVersion: 2
    x: 800
    y: 351
    width: 200
    height: 100
  m_onEnterAction: 
  m_onExitAction: Give Standard Hoe
  m_condition:
    m_AND: []
